{
  "id": "intelligent-investor",
  "name": "Graham — Defensive Investor",
  "description": "Graham's 7 defensive criteria + Graham number margin of safety. IDX size threshold relaxed to IDR 5T.",
  "rules": [
    {"name": "adequate-size",        "expr": "market_cap >= 5e12",                                                 "weight": 1.0, "note": "IDR 5T cap floor"},
    {"name": "strong-current-ratio", "expr": "current_ratio >= 2",                                                 "weight": 1.0},
    {"name": "earnings-stability",   "expr": "eps_growth_streak_annual >= 10 or net_income_growth_streak_ann >= 10","weight": 1.0},
    {"name": "dividend-record",      "expr": "div_streak_annual >= 10",                                            "weight": 1.0},
    {"name": "earnings-growth",      "expr": "eps_3y_cagr >= 3",                                                   "weight": 1.0, "note": "33% over 10y ~= 2.9% CAGR"},
    {"name": "moderate-pe",          "expr": "pe_ttm > 0 and pe_ttm <= 15",                                        "weight": 1.0},
    {"name": "moderate-pb",          "expr": "pbv > 0 and pe_ttm * pbv <= 22.5",                                   "weight": 1.0, "note": "Graham combined valuation"},
    {"name": "graham-margin",        "expr": "graham_multiplier is not None and price <= graham_multiplier * 0.67","weight": 1.5, "note": "≥33% MoS to Graham number"},
    {"name": "no-distress",          "expr": "der < 2 and interest_coverage > 1.5",                                "weight": 1.0, "veto": true}
  ]
}
